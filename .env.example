# Network Traffic Monitor Configuration

# Flask Backend Settings
FLASK_PORT=5000
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1

# Email Alert Settings (Optional - leave blank to skip email alerts)
# To set up Gmail alerts:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below

# Sender email address (the account sending alerts)
ALERT_EMAIL_SENDER=your-email@gmail.com

# Receiver email address (where alerts are sent)
# Can also be set via the UI Settings tab
ALERT_EMAIL_RECEIVER=security@yourcompany.com

# SMTP password (required to send emails)
# IMPORTANT: For security, always set this as an environment variable, not in code
ALERT_EMAIL_PASSWORD=your-app-password-here

# SMTP server host (default: smtp.gmail.com for Gmail)
ALERT_SMTP_HOST=smtp.gmail.com

# SMTP server port (default: 465 for SSL, 587 for TLS)
ALERT_SMTP_PORT=465

# SMTP username (usually same as sender email)
ALERT_SMTP_USER=your-email@gmail.com

# Use SSL for SMTP connection (True/False, default: True)
ALERT_SMTP_SSL=True

# Frontend Settings
REACT_PORT=3000
REACT_DEBUG=False

# Logging
LOG_LEVEL=INFO

# ML Model Settings
ML_MODEL_ENABLED=True
ML_ANOMALY_THRESHOLD=0.5
